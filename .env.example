# Required for docker-compose local development
# Copy this file to .env and fill in your values

# Azure AD Configuration (required for both frontend MSAL fallback and backend OBO)
MSAL_CLIENT_ID=<Azure AD Application (client) ID>
MSAL_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
MSAL_SCOPES=api://localhost:3000/<client-id>/access_as_user
MSAL_SECRET=<Azure AD Client Secret>

# Optional: JWT secret for backend — must match the secret configured in Open Zaak.
# The local docker-compose default (openZaakSecretKey) matches the SQL seed in
# scripts/docker-compose/open-zaak/openzaak-database/database/1-setup-office-add-in-config.sql
# JWT_SECRET=openZaakSecretKey

# Optional: SSL certificate paths for local non-Docker development
# KEY_PATH=../ssl-certs/key.pem
# CERT_PATH=../ssl-certs/cert.pem
# CA_CERT_PATH=../ssl-certs/ca-cert.pem
